# ── Editors ──────────────────────────────────────────────────────────────────
alias vim="nvim"
alias vi="nvim"

alias oil="nvim -c Oil"   # open nvim directly in Oil file explorer

# ── TUI Tools ─────────────────────────────────────────────────────────────────
alias lgit="lazygit"
alias dash="gh dash"      # GitHub dashboard (gh-dash)

# ── Shell ─────────────────────────────────────────────────────────────────────
alias c="clear"
alias Q="exit"

# ── Config Reload ─────────────────────────────────────────────────────────────
alias zsrc="source ~/.zshrc"
alias bsrc="source ~/.bashrc"
alias tsrc="tmux source ~/.tmux.conf"

# ── System Updates ────────────────────────────────────────────────────────────
alias ubupdate="sudo apt update && sudo apt upgrade"  # Ubuntu
alias arupdate="sudo pacman -Syu"                     # Arch
alias omupdate="omarchy update"                       # Omarchy desktop

# ── Colors ────────────────────────────────────────────────────────────────────
if [ -x /usr/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
    alias ls='ls --color=auto'

    alias grep='grep --color=auto'
    alias fgrep='fgrep --color=auto'
    alias egrep='egrep --color=auto'
fi

# ── Navigation ────────────────────────────────────────────────────────────────
alias ..='cd ..'

# ── File Listing ──────────────────────────────────────────────────────────────
alias ll='ls -alF'   # long list, all files, classify
alias la='ls -A'     # all files, no . and ..
alias l='ls -CF'     # columns, classify

# ── Git ───────────────────────────────────────────────────────────────────────
alias gs="git status"
alias ga="git add"
alias gaa="git add --all"
alias gc="git commit -m"
alias gca="git commit --amend"
alias gps="git push"
alias gpl="git pull"
alias gd="git diff"
alias grs="git restore --staged"    # unstage single file
alias grsa="git restore --staged ." # unstage all

# git log variants
alias gl="git log --decorate --all"
alias glo="git log --oneline --decorate --all"
alias gld="git log --pretty=format:'%h %ad | %s%d [%an]' --graph --date=short"

# branch management
alias gb="git branch"
alias gsw="git switch"
alias gswc="git switch -c"  # create and switch to new branch
alias gm="git merge"

# ── Misc ──────────────────────────────────────────────────────────────────────
alias open="xdg-open"   # xdg open (Linux equivalent of macOS open)

# ── Functions ─────────────────────────────────────────────────────────────────

# create or attach to a tmux session by name
tmuxnew() {
    if [ -z "$1" ]; then
        echo "Usage: tmmuxnew <nome_da_sessao>"
        return 1
    fi

    SESSION_NAME="$1"

    if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
        tmux attach-session -t "$SESSION_NAME"
    else
        tmux new-session -d -s "$SESSION_NAME"
        tmux attach-session -t "$SESSION_NAME"
    fi
}

# connect to a local postgres db with user and port
psqlnew() {
    if [ -z "$1" ]; then
        echo "Usage: psqlnew <user> <port>"
        return 1
    fi
	DB_USER="$1"
    DB_PORT="$2"
    psql -U "$DB_USER" -p "$DB_PORT" -h localhost -d postgres
}

# shorthand for aichat
ai() {
    if [ -z "$*" ]; then
        echo "Usage: ai <question>"
        return 1
    fi
    aichat "$*"
}

# mkdir + cd in one step
mkcd() {
  mkdir -p "$1" && cd "$1"
}
